# DATABASE (Supabase Postgres)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].supabase.com:5432/postgres"

# API
PORT=3000
CORS_ORIGINS="http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004"

# Pollar (server-only — never expose to the browser)
POLLAR_SECRET_KEY="sec_testnet_xxxxxxxxxxxxxxxxxxxx"
POLLAR_SDK_BASE_URL="https://sdk.api.pollar.xyz/v1"
