{
  "name": "cminds",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=core-api",
    "dev:cminds": "turbo run dev --filter=cminds-dashboard",
    "dev:community": "turbo run dev --filter=community-dashboard",
    "dev:funding": "turbo run dev --filter=funding-dashboard",
    "dev:public": "turbo run dev --filter=public-viewer",
    "dev:admin": "turbo run dev --filter=admin",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.12.0"
  }
}
