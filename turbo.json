{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [".env*"],
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_POLLAR_API_KEY",
    "NEXT_PUBLIC_CORE_API_URL",
    "NEXT_PUBLIC_TRUSTLESS_WORK_API_KEY",
    "NEXT_PUBLIC_USE_MAINNET",
    "NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID",
    "DATABASE_URL",
    "DIRECT_URL",
    "PORT",
    "POLLAR_SECRET_KEY",
    "POLLAR_API_KEY",
    "POLLAR_SDK_BASE_URL",
    "POLLAR_ORIGIN",
    "CORS_ORIGINS",
    "SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_JWT_SECRET",
    "SUPABASE_ESCROW_IMAGES_BUCKET",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**", "lib/**", "runtime/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
